APP_NAME=SafeBrowse AI API
API_PREFIX=/api
JWT_SECRET=change-me-local-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg2://safebrowse:safebrowse@localhost:5432/safebrowse
CLIENT_BASE_URL=http://localhost:5173
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ROBERTA_ENABLED=true
ROBERTA_MODEL_NAME=roberta-large-mnli
ROBERTA_MAX_LENGTH=512
WEIGHT_EMOTIONAL=0.52
WEIGHT_SOURCE_INVERSE=0.33
WEIGHT_STRUCTURE=0.15
THRESHOLD_CAUTION=0.28
THRESHOLD_NO_GO=0.45
THRESHOLD_HARD_NO_GO=0.65
